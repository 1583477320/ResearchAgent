# 大语言模型配置
LLM_PROVIDER=deepseek

# 通义千问配置
LLM_API_BASE_URL=https://api.qwenlm.com/v1
LLM_API_KEY=your_qwen_api_key_here
LLM_MODEL_NAME=qwen3-7b-chat

# DeepSeek 配置
DEEPSEEK_API_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL_NAME=deepseek-chat

# 其他配置
ARXIV_API_URL=https://export.arxiv.org/api/query
LOG_LEVEL=INFO
MAX_CRITIC_ITERATIONS=2      # critic loop iterations (1=fast, 3=thorough)
DEFAULT_MAX_PAPERS=5

# 记忆系统配置
MEMORY_DB_PATH=memory.db
MEMORY_ENABLED=true
LLM_CACHE_ENABLED=true
LLM_CACHE_TTL_HOURS=48
EMBEDDING_MODEL_NAME=
VECTOR_STORE_PATH=vector_store
